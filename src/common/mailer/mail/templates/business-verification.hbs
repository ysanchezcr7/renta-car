<!DOCTYPE html>
<html lang='es'>
	<head>
		<meta charset='UTF-8' />
		<meta name='viewport' content='width=device-width, initial-scale=1.0' />
		<meta http-equiv='X-UA-Compatible' content='IE=edge' />
		<title>Verificación de Negocio - Bookealo</title>
		<style>
			* {
				margin: 0;
				padding: 0;
				box-sizing: border-box;
			}
			body {
				font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
				background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
				padding: 40px 20px;
				line-height: 1.6;
			}
			.email-wrapper {
				max-width: 600px;
				margin: 0 auto;
				background: #ffffff;
				border-radius: 20px;
				overflow: hidden;
				box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
			}
			.header {
				background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
				padding: 50px 30px;
				text-align: center;
			}
			.logo {
				max-width: 140px;
				height: auto;
				margin-bottom: 20px;
				filter: brightness(0) invert(1);
			}
			.content {
				padding: 50px 40px;
				text-align: center;
			}
			.icon-container {
				width: 100px;
				height: 100px;
				margin: 0 auto 30px;
				border-radius: 50%;
				display: flex;
				align-items: center;
				justify-content: center;
				font-size: 50px;
			}
			.icon-success {
				background: linear-gradient(135deg, #48bb78 0%, #38a169 100%);
			}
			.icon-failed {
				background: linear-gradient(135deg, #f56565 0%, #e53e3e 100%);
			}
			.title {
				font-size: 32px;
				font-weight: 800;
				margin-bottom: 20px;
			}
			.title-success {
				color: #38a169;
			}
			.title-failed {
				color: #e53e3e;
			}
			.greeting {
				font-size: 18px;
				color: #2d3748;
				margin-bottom: 30px;
				font-weight: 500;
			}
			.business-card {
				background: #ffffff;
				border-radius: 16px;
				padding: 25px;
				margin: 30px 0;
				border: 1px solid #e2e8f0;
				border-left: 5px solid #718096;
				box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
			}
			.business-card-success {
				border-left-color: #48bb78;
			}
			.business-card-failed {
				border-left-color: #f56565;
			}
			.business-name {
				font-size: 24px;
				font-weight: 700;
				color: #2d3748;
				margin-bottom: 10px;
			}
			.business-owner {
				font-size: 16px;
				color: #4a5568;
			}
			.message {
				font-size: 16px;
				color: #2d3748;
				margin: 30px 0;
				line-height: 1.8;
			}
			.button-container {
				margin: 35px 0;
			}
			.action-button {
				display: inline-block;
				padding: 16px 35px;
				color: #ffffff !important;
				text-decoration: none;
				border-radius: 12px;
				font-weight: 700;
				font-size: 16px;
				box-shadow: 0 10px 25px rgba(0, 0, 0, 0.2);
			}
			.button-success {
				background: linear-gradient(135deg, #48bb78 0%, #38a169 100%);
			}
			.button-retry {
				background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
			}
			.info-box {
				border-radius: 12px;
				padding: 20px;
				margin: 30px 0;
				border-left: 4px solid #718096;
			}
			.info-box-success {
				background: #f0fff4;
				border-left-color: #48bb78;
			}
			.info-box-failed {
				background: #fff5f5;
				border-left-color: #f56565;
			}
			.info-text {
				font-size: 14px;
				margin: 0;
				text-align: left;
			}
			.info-text-success {
				color: #22543d;
			}
			.info-text-failed {
				color: #c53030;
			}
			.footer {
				background: #f7fafc;
				padding: 30px 40px;
				text-align: center;
				border-top: 1px solid #e2e8f0;
			}
			.footer-links {
				margin-bottom: 20px;
			}
			.footer-link {
				color: #667eea;
				text-decoration: none;
				font-size: 14px;
				margin: 0 10px;
			}
			.copyright {
				font-size: 12px;
				color: #a0aec0;
				margin-top: 20px;
			}
			@media only screen and (max-width: 600px) {
				.content {
					padding: 30px 20px;
				}
				.title {
					font-size: 26px;
				}
			}
		</style>
	</head>
	<body>
		<div class='email-wrapper'>
			<div class='header'>
				<img class='logo' src='https://res.cloudinary.com/dux5ebiqb/image/upload/v1748394763/logo_bokealo.png' alt='Bookealo Logo' />
			</div>
			<div class='content'>
				<div class='icon-container {{#if verified}}icon-success{{else}}icon-failed{{/if}}'>
					{{#if verified}}✅{{else}}❌{{/if}}
				</div>
				<h1 class='title {{#if verified}}title-success{{else}}title-failed{{/if}}'>
					{{title}}
				</h1>
				<p class='greeting'>{{#if lang}}{{#if (eq lang "es")}}Hola{{else}}Hello{{/if}}{{else}}Hello{{/if}} <strong>{{name}}</strong>,</p>
				<div class='business-card {{#if verified}}business-card-success{{else}}business-card-failed{{/if}}'>
					<div class='business-name'>{{businessName}}</div>
					<div class='business-owner'>{{owner}} {{name}}</div>
				</div>
				<p class='message'>
					{{message}}
					<br /><br />
					{{submessage}}
				</p>
				<div class='button-container'>
					{{#if verified}}
						<a href='{{dashboardLink}}' class='action-button button-success'>{{button}}</a>
					{{else}}
						<a href='{{retryLink}}' class='action-button button-retry'>{{button}}</a>
					{{/if}}
				</div>
				<div class='info-box {{#if verified}}info-box-success{{else}}info-box-failed{{/if}}'>
					<p class='info-text {{#if verified}}info-text-success{{else}}info-text-failed{{/if}}'>
						{{info}}
					</p>
				</div>
			</div>
			<div class='footer'>
				<div class='footer-links'>
					<a href='mailto:bookealoapp@gmail.com' class='footer-link'>{{support}}</a>
					<span>|</span>
					<a href='https://www.bookealoapp.com/' class='footer-link'>{{website}}</a>
				</div>
				<p class='copyright'>{{copyright}}</p>
			</div>
		</div>
	</body>
</html>
