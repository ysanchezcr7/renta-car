<!DOCTYPE html>
<html lang='es'>
	<head>
		<meta charset='UTF-8' />
		<meta name='viewport' content='width=device-width, initial-scale=1.0' />
		<meta http-equiv='X-UA-Compatible' content='IE=edge' />
		<title>Verifica tu Email - Bookealo</title>
		<style>
			* {
				margin: 0;
				padding: 0;
				box-sizing: border-box;
			}
			body {
				font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
				background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
				padding: 40px 20px;
				line-height: 1.6;
			}
			.email-wrapper {
				max-width: 600px;
				margin: 0 auto;
				background: #ffffff;
				border-radius: 20px;
				overflow: hidden;
				box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
			}
			.header {
				background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
				padding: 50px 30px;
				text-align: center;
				position: relative;
			}
			.header::before {
				content: '';
				position: absolute;
				top: 0;
				left: 0;
				right: 0;
				bottom: 0;
				background: url('data:image/svg+xml,<svg width="100" height="100" xmlns="http://www.w3.org/2000/svg"><circle cx="50" cy="50" r="2" fill="rgba(255,255,255,0.1)"/></svg>');
				opacity: 0.3;
			}
			.logo {
				max-width: 140px;
				height: auto;
				margin-bottom: 20px;
				position: relative;
				z-index: 1;
				filter: brightness(0) invert(1);
			}
			.content {
				padding: 50px 40px;
				text-align: center;
			}
			.title {
				font-size: 32px;
				font-weight: 800;
				color: #1a202c;
				margin-bottom: 20px;
				background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
				-webkit-background-clip: text;
				-webkit-text-fill-color: transparent;
				background-clip: text;
			}
			.brand-name {
				font-size: 36px;
				font-weight: 900;
				color: #667eea;
				margin: 20px 0;
				letter-spacing: -1px;
			}
			.message {
				font-size: 16px;
				color: #4a5568;
				margin-bottom: 40px;
				line-height: 1.8;
			}
			.button-container {
				margin: 40px 0;
			}
			.verify-button {
				display: inline-block;
				padding: 18px 40px;
				background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
				color: #ffffff !important;
				text-decoration: none;
				border-radius: 12px;
				font-weight: 700;
				font-size: 16px;
				box-shadow: 0 10px 25px rgba(102, 126, 234, 0.4);
				transition: all 0.3s ease;
				letter-spacing: 0.5px;
			}
			.verify-button:hover {
				transform: translateY(-2px);
				box-shadow: 0 15px 35px rgba(102, 126, 234, 0.5);
			}
			.info-box {
				background: #f0f4ff;
				border-radius: 12px;
				padding: 20px;
				margin: 30px 0;
				border-left: 4px solid #667eea;
			}
			.info-text {
				font-size: 14px;
				color: #4a5568;
				margin: 0;
				text-align: left;
			}
			.footer {
				background: #f7fafc;
				padding: 30px 40px;
				text-align: center;
				border-top: 1px solid #e2e8f0;
			}
			.footer-links {
				margin-bottom: 20px;
			}
			.footer-link {
				color: #667eea;
				text-decoration: none;
				font-size: 14px;
				margin: 0 10px;
			}
			.footer-link:hover {
				text-decoration: underline;
			}
			.copyright {
				font-size: 12px;
				color: #a0aec0;
				margin-top: 20px;
			}
			@media only screen and (max-width: 600px) {
				.content {
					padding: 30px 20px;
				}
				.title {
					font-size: 26px;
				}
				.brand-name {
					font-size: 28px;
				}
				.verify-button {
					padding: 16px 30px;
					font-size: 14px;
				}
			}
		</style>
	</head>
	<body>
		<div class='email-wrapper'>
			<div class='header'>
				<img class='logo' src='https://res.cloudinary.com/dux5ebiqb/image/upload/v1748394763/logo_bokealo.png' alt='Bookealo Logo' />
			</div>
			<div class='content'>
				<h1 class='title'>{{title}}</h1>
				<div class='brand-name'>{{brandName}}</div>
				<p class='message'>
					{{message}}
					<br />
					{{verifyMessage}}
				</p>
				<div class='button-container'>
					<a href='{{VERIFICATION_LINK}}' class='verify-button'>{{button}}</a>
				</div>
				<div class='info-box'>
					<p class='info-text'>
						{{info}}
					</p>
				</div>
			</div>
			<div class='footer'>
				<div class='footer-links'>
					<a href='mailto:bookealoapp@gmail.com' class='footer-link'>{{support}}</a>
					<span>|</span>
					<a href='https://www.bookealoapp.com/' class='footer-link'>{{website}}</a>
				</div>
				<p class='copyright'>{{copyright}}</p>
			</div>
		</div>
	</body>
</html>
