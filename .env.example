# =============================================================================
# Renta Car API — variables locales (no subir al repo).
# Alineado con .env.example y docker-compose.yml (postgres + api en 3001).
# =============================================================================

# Base de datos (PostgreSQL)
# API en el host (fuera de Docker): localhost + puerto publicado del contenedor.
# Valores por defecto iguales que docker-compose (POSTGRES_*).
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/renta_car?schema=public"
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=renta_car
# Puerto del contenedor postgres en el host (si 5432 está ocupado, cambia aquí y en la URL).
# POSTGRES_PUBLISH_PORT=5432

# Servidor (compose mapea ${PORT:-3001}:3001)
PORT=3001
HOST_URL=http://localhost:3001

# JWT — genera valores fuertes en producción
JWT_SECRET="tu-clave-secreta-muy-segura-cambiar-en-produccion"

# Encriptación para tokens de verificación de email (mín. 32 caracteres)
EMAIL_ENCRYPT_SECRET="clave-32-caracteres-para-encriptar"

# URLs de verificación de email
EMAIL_VERIFICATION_URL="/api/v1/auth/verify-email/"
VERIFY_EMAIL_SUCCESS_URL="http://localhost:3001/verify-email/success"
VERIFY_EMAIL_ERROR_URL="http://localhost:3001/verify-email/error"

# -----------------------------------------------------------------------------
# Correo (rellena con tu proveedor real)
# -----------------------------------------------------------------------------
MAIL_PASS=Cristian201218**
MAIL_HOST=mail.privateemail.com
MAIL_PORT=465
MAIL_USER=info@ysoftmultiservice.com
MAIL_FROM=Renta Car <info@ysoftmultiservice.com>


# -----------------------------------------------------------------------------
