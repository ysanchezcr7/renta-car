# -----------------------------------------------------------------------------
# Gemini / IA (opcional)
# -----------------------------------------------------------------------------
# GEMINI_API_KEY=...

# -----------------------------------------------------------------------------
# Validación gubernamental de fotos de pasaporte (Playwright)
# -----------------------------------------------------------------------------
GOV_PHOTO_CHECK_ENABLED=true
GOV_PHOTO_CHECK_TIMEOUT=30000

# -----------------------------------------------------------------------------
# Google Cloud / Vertex AI (opcional)
