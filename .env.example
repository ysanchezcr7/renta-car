# =============================================================================
# Variables principales (template base Auth + Users + Prisma)
# Copia este archivo a .env y rellena los valores. No subas .env al repositorio.
# =============================================================================

# Base de datos (PostgreSQL)
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/template?schema=public"
POSTGRES_PASSWORD="tu-password-postgres"

# Servidor
PORT=3001
HOST_URL="http://localhost:3001"

# JWT
JWT_SECRET="tu-clave-secreta-muy-segura-cambiar-en-produccion"

# Encriptación para tokens de verificación de email (mín. 32 caracteres)
EMAIL_ENCRYPT_SECRET="clave-32-caracteres-para-encriptar"

# URLs de verificación de email
EMAIL_VERIFICATION_URL="/api/v1/auth/verify-email/"
VERIFY_EMAIL_SUCCESS_URL="http://localhost:3001/verify-email/success"
VERIFY_EMAIL_ERROR_URL="http://localhost:3001/verify-email/error"

# -----------------------------------------------------------------------------
# Correo (para OTP, verificación, etc.)
# -----------------------------------------------------------------------------
MAIL_HOST="smtp.ejemplo.com"
MAIL_PORT=465
MAIL_USER="tu-email@ejemplo.com"
MAIL_PASS="tu-password-email"
MAIL_FROM="Tu App <tu-email@ejemplo.com>"

# -----------------------------------------------------------------------------
# Ngrok (opcional, para exponer localhost)
# -----------------------------------------------------------------------------
# NGROK_AUTHTOKEN="tu-token-ngrok"

# -----------------------------------------------------------------------------
# Stripe (opcional; si usas pagos/membresías)
# -----------------------------------------------------------------------------
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_MONTHLY=price_...
# STRIPE_PRICE_QUARTERLY=price_...
# STRIPE_PRICE_YEARLY=price_...
# STRIPE_PLATFORM_FEE_PERCENTAGE=1
# MEMBERSHIP_TRIAL_DAYS=60

# -----------------------------------------------------------------------------
# Apple In-App / App Store (opcional)
# -----------------------------------------------------------------------------
# APPLE_PRICE_MONTHLY=com.tuapp.monthly
# APPLE_PRICE_QUARTERLY=com.tuapp.quarterly
# APPLE_PRICE_YEARLY=com.tuapp.yearly
# APPLE_SHARED_SECRET_CLIENT=...
# APPLE_SHARED_SECRET_ADMIN=...
# APPLE_PRODUCT_ID_CREDITS_TOPUP=com.tuapp.credits
# AI_CREDITS_TOPUP_PRICE=7.99
# AI_CREDITS_TOPUP_AMOUNT=50

# -----------------------------------------------------------------------------
# Twilio SMS (opcional)
# -----------------------------------------------------------------------------
# TWILIO_ACCOUNT_SID=AC...
# TWILIO_AUTH_TOKEN=...
# TWILIO_PHONE_NUMBER=+1234567890

# -----------------------------------------------------------------------------
# Firebase Cloud Messaging (opcional; notificaciones push)
# -----------------------------------------------------------------------------
# FCM_PROJECT_ID=tu-proyecto-admin
# FCM_CLIENT_EMAIL=firebase-adminsdk-...@tu-proyecto.iam.gserviceaccount.com
# FCM_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# FCM_PROJECT_ID_COSTUMER=tu-proyecto-cliente
# FCM_CLIENT_EMAIL_COSTUMER=firebase-adminsdk-...@tu-proyecto.iam.gserviceaccount.com
# FCM_PRIVATE_KEY_COSTUMER="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# -----------------------------------------------------------------------------
# Cookies / sesión
# -----------------------------------------------------------------------------
# COOKIE_SECRET="clave-secreta-32-o-mas-caracteres"

# -----------------------------------------------------------------------------
# Gemini / IA (opcional)
# -----------------------------------------------------------------------------
# GEMINI_API_KEY=...

# -----------------------------------------------------------------------------
# Google Cloud / Vertex AI (opcional)
# -----------------------------------------------------------------------------
# GOOGLE_CLOUD_PROJECT_ID=tu-proyecto
# GOOGLE_CLOUD_LOCATION=us-central1
# GOOGLE_APPLICATION_CREDENTIALS=/ruta/absoluta/a/tu-service-account.json

# -----------------------------------------------------------------------------
# Verificación de negocio (opcional)
# -----------------------------------------------------------------------------
# VIRIFY_BUSINESS_API_URL_COMPANY_SEARCH=Inquiry/corporationsearch/SearchResults?inquiryType=FeiNumber&searchTerm
# VIRIFY_BUSINESS_URL_BASE=https://search.sunbiz.org/
